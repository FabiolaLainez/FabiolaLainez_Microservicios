{
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "products",
        "ClusterId": "productCluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      {
        "RouteId": "customers",
        "ClusterId": "customerCluster",
        "Match": { "Path": "/api/customers/{**catch-all}" }
      },
      {
        "RouteId": "orders",
        "ClusterId": "orderCluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      }
    ],
    "Clusters": {
      "productCluster": {
        "Destinations": {
          "d1": { "Address": "http://productservice:80/" }
        }
      },
      "customerCluster": {
        "Destinations": {
          "d1": { "Address": "http://customerservice:80/" }
        }
      },
      "orderCluster": {
        "Destinations": {
          "d1": { "Address": "http://orderservice:80/" }
        }
      }
    }
  }
}